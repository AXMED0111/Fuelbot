      log('SHEETS','sheets','✔ Google Sheets connected — ' + (d.message||'OK') + ' · version: ' + (d.version||'v3'));
      document.getElementById('sheets-conn-status').textContent = '✔ Connected';
      document.getElementById('sheets-conn-status').style.color = 'var(--green)';
    } else {
      log('SHEETS','warn','Sheets responded but returned: ' + JSON.stringify(d));
    }
  } catch(e) {
    log('SHEETS','warn','Sheets auto-test failed (CORS expected in browser) — will work when trading');
  }
}, 2000);
setInterval(drawChart,9000);
window.addEventListener('resize',drawChart);

</script>
