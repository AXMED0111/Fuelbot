// ─── TRADE CALCULATION & PROFIT ESTIMATOR ─────────────────────
function calculateTrade() {
  const p=STATE.price, sig=STATE.lastSignal;
  const slDist = SETTINGS.slDist/100;
  const balance = SETTINGS.balance;
  const riskAmt = balance*(SETTINGS.riskPct/100);

  // update KV labels
  document.getElementById('kv-risk').textContent = SETTINGS.riskPct+'%';
  document.getElementById('kv-sl-dist').textContent = SETTINGS.slDist+'%';
  document.getElementById('kv-tp1-r').textContent = SETTINGS.tp1R;
  document.getElementById('kv-tp2-r').textContent = SETTINGS.tp2R;
  document.getElementById('pr-balance').textContent = fmt$(balance,0);

  if(!p||sig==='wait'||sig==='skip'){
    ['kv-entry','kv-sl','kv-tp1','kv-tp2','tc-entry','tc-sl','tc-tp1','tc-tp2','pr-size','pr-loss','pr-tp1','pr-tp2','pr-per-ex'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.textContent='—';
    });
    document.getElementById('kv-dir').textContent='—';
    document.getElementById('kv-dir').style.color='var(--muted2)';
    document.getElementById('pb-gain').style.width='0%';
    document.getElementById('exec-row').style.display='none';
    return;
  }

  let sl, tp1, tp2, slDistAbs, dir;
  if(sig==='buy'){
    sl     = p*(1-slDist);
    slDistAbs = p-sl;
    tp1    = p+slDistAbs*SETTINGS.tp1R;
    tp2    = p+slDistAbs*SETTINGS.tp2R;
    dir    = '▲ LONG';
    document.getElementById('kv-dir').style.color='var(--green)';
  } else {
    sl     = p*(1+slDist);
    slDistAbs = sl-p;
    tp1    = p-slDistAbs*SETTINGS.tp1R;
    tp2    = p-slDistAbs*SETTINGS.tp2R;
    dir    = '▼ SHORT';
    document.getElementById('kv-dir').style.color='var(--red)';
  }

  // Position sizing: risk amount / SL distance in %
  const positionUSDT = riskAmt / slDist * 100;
  const positionBTC  = positionUSDT / p;
  const maxLoss      = riskAmt;
  const profitTP1    = positionBTC * Math.abs(tp1-p);
  const profitTP2    = positionBTC * Math.abs(tp2-p);
  const activeEx     = Object.values(EXCHANGES).filter(e=>e.enabled).length;
  const profitPerEx  = profitTP1 / Math.max(activeEx,1);

  document.getElementById('kv-dir').textContent=dir;
  document.getElementById('kv-entry').textContent=fmtCoin(p);
  document.getElementById('kv-sl').textContent=fmtCoin(sl);
  document.getElementById('kv-tp1').textContent=fmtCoin(tp1);
  document.getElementById('kv-tp2').textContent=fmtCoin(tp2);
  document.getElementById('tc-entry').textContent=fmtCoin(p);
  document.getElementById('tc-sl').textContent=fmtCoin(sl);
  document.getElementById('tc-tp1').textContent=fmtCoin(tp1);
  document.getElementById('tc-tp2').textContent=fmtCoin(tp2);

  // Profit panel
  document.getElementById('pr-size').textContent  = positionBTC.toFixed(4)+' BTC';
  document.getElementById('pr-loss').textContent  = '-'+fmt$(maxLoss);
  document.getElementById('pr-tp1').textContent   = '+'+fmt$(profitTP1);
  document.getElementById('pr-tp2').textContent   = '+'+fmt$(profitTP2);
  document.getElementById('pr-per-ex').textContent= '+'+fmt$(profitPerEx)+'/ex';

  // Profit bar
  const totalRange = maxLoss+profitTP2;
  document.getElementById('pb-loss').style.width  = (maxLoss/totalRange*100)+'%';
  document.getElementById('pb-gain').style.width  = (profitTP2/totalRange*100)+'%';

  // Show execute buttons
  document.getElementById('exec-row').style.display='flex';
}

// ─── EVALUATE SIGNAL ──────────────────────────────────────────
function evaluate() {
  const t     = gmt3();
  const inSess = isInSession(t);
  const c     = STATE.candles;
  const p     = STATE.price;
  const gc    = STATE.greenCount;

  if(!p||!c.length) return;

  let score=0;

  // F1: session
  if(inSess) score+=2;
  setFilter('f-session',inSess?'pass':'fail',inSess?sessionName(t):'OFF-SESSION');

  // F2: 2/3 green
  if(gc>=2) score+=2;
  setFilter('f-candle',gc>=2?'pass':'fail',`${gc}/3`);

  // F3: BOR breakout
  let borPass=false,borLbl='—';
  if(STATE.borHigh&&STATE.borLow){
    if(p>STATE.borHigh){borPass=true;borLbl='▲ HIGH BREAK';score+=1.5;}
    else if(p<STATE.borLow){borPass=true;borLbl='▼ LOW BREAK';score+=1.5;}
    else if(p>STATE.borMid){borLbl='UPPER ZONE';score+=0.5;}
    else borLbl='LOWER ZONE';
  }
  setFilter('f-bor',borPass?'pass':STATE.borHigh?'warn':'idle',borLbl);

  // F4: momentum alignment
  const bullDir = gc>=2&&c[2]&&c[2].green;
  const bearDir = gc>=2&&c[2]&&!c[2].green;
  let momAlign=false,momLbl='—';
  if(bullDir&&STATE.momentum>0){momAlign=true;momLbl='▲ ALIGNED';score+=1.5;}
  else if(bearDir&&STATE.momentum<0){momAlign=true;momLbl='▼ ALIGNED';score+=1.5;}
  else momLbl=STATE.momentum>0?'▲ UP':'STATE.momentum<0'?'▼ DOWN':'FLAT';
  setFilter('f-mom',momAlign?'pass':'warn',momLbl);

  // F5: candle trend
  const allG=gc===3, allR=gc===0;
  if(allG||allR) score+=1;
  setFilter('f-trend',(allG||allR)?'pass':gc>=2?'warn':'fail',allG?'FULL BULL':allR?'FULL BEAR':`MIXED ${gc}/3`);

  // F6: news
  setFilter('f-news',STATE.newsActive?'fail':'pass',STATE.newsActive?'NEWS ACTIVE':'CLEAR');
  if(STATE.newsActive) score-=5;

  // F7: candle body size
  let bodyOk=false,bodyLbl='—';
  if(c.length){
    const avg=c.reduce((a,cv)=>a+Math.abs(cv.pct),0)/c.length;
    bodyOk=avg>0.05;
    bodyLbl=avg.toFixed(3)+'% avg';
    if(bodyOk) score+=1;
  }
  setFilter('f-body',bodyOk?'pass':'warn',bodyLbl);

  // F8: daily trade limit
  const limitOk = STATE.dailyTrades<SETTINGS.maxTrades;
  setFilter('f-maxtr',limitOk?'pass':'fail',`${STATE.dailyTrades}/${SETTINGS.maxTrades}`);
  if(!limitOk) score-=10;

  score=Math.max(0,Math.min(10,score));
  STATE.score=score;
  updateScoreRing(score);

  const conf=Math.round(score/10*100);
  document.getElementById('conf-num').textContent=conf+'%';
  document.getElementById('conf-fill').style.width=conf+'%';

  // ── SIGNAL DECISION ──
  if(STATE.newsActive) {
    setSignal('⚠','SKIP','News event — trading suspended','s-skip');
    STATE.lastSignal='skip';
  } else if(!limitOk) {
    setSignal('🔒','LIMIT','Daily trade limit reached','s-skip');
    STATE.lastSignal='skip';
  } else if(!inSess) {
    setSignal('◈','WAIT','Monitoring 4AM / 4PM sessions…','s-wait');
    STATE.lastSignal='wait';
  } else if(gc<2) {
    setSignal('✕','SKIP',`Only ${gc}/3 green candles`,'s-skip');
    if(STATE.lastSignal!=='skip'){log('SKIP','skip',`Only ${gc}/3 green — no entry`);STATE.lastSignal='skip';}
  } else if(c[2]&&c[2].green) {
    setSignal('▲','BUY','2+ green · long entry confirmed','s-buy');
    if(STATE.lastSignal!=='buy'){
      log('BUY','buy',`Long · score ${score.toFixed(1)}/10 · ${gc}/3 green`);
      STATE.lastSignal='buy';
      autoFireTrades('buy');
    }
  } else {
    setSignal('▼','SELL','Reversal detected · short entry','s-sell');
    if(STATE.lastSignal!=='sell'){
      log('SELL','sell',`Short · score ${score.toFixed(1)}/10 · last candle reversal`);
      STATE.lastSignal='sell';
      autoFireTrades('sell');
    }
  }

  calculateTrade();
}

function setSignal(icon,word,sub,cls){
  document.getElementById('sig-icon').textContent=icon;
  document.getElementById('sig-word').textContent=word;
  document.getElementById('sig-sub').textContent=sub;
  document.getElementById('sig-box').className='signal-main '+cls;
}

function setFilter(id,status,val){
  const dot=document.getElementById(id+'-dot');
  const ve=document.getElementById(id+'-val');
  if(dot) dot.className='filter-dot '+status;
  if(ve){ve.textContent=val;ve.style.color=status==='pass'?'var(--green)':status==='fail'?'var(--red)':status==='warn'?'var(--yellow)':'var(--muted2)';}
}

function updateScoreRing(score){
  const arc=document.getElementById('score-arc');
  const off=314-(314*(score/10));
  arc.style.strokeDashoffset=off;
  arc.style.stroke=score>=7?'var(--green)':score>=4?'var(--yellow)':'var(--red)';
  document.getElementById('score-num').textContent=score.toFixed(1);
  document.getElementById('score-num').setAttribute('fill',score>=7?'var(--green)':score>=4?'var(--yellow)':'var(--red)');
  const lbs=['NO DATA','VERY WEAK','WEAK','BELOW AVG','AVERAGE','MODERATE','GOOD','STRONG','VERY STRONG','EXCELLENT','PERFECT'];
  document.getElementById('score-label').textContent=lbs[Math.round(score)];
}

// ─── TRADE EXECUTION ──────────────────────────────────────────
async function autoFireTrades(direction){
  const inSess = isInSession(gmt3());
  if(!inSess||STATE.newsActive||STATE.dailyTrades>=SETTINGS.maxTrades) return;
  for(const [name,ex] of Object.entries(EXCHANGES)){
    if(ex.enabled) await placeOrder(name, direction);
  }
}

async function executeTrade(direction){
  if(!STATE.price){log('ERR','warn','No price data — cannot execute');return;}
  if(STATE.dailyTrades>=SETTINGS.maxTrades){log('LIMIT','warn','Daily trade limit reached');return;}
  for(const [name,ex] of Object.entries(EXCHANGES)){
    if(ex.enabled) await placeOrder(name, direction);
  }
}

async function placeOrder(exchangeName, direction){
  const ex = EXCHANGES[exchangeName];
  if(!ex.enabled) return;
  const p   = STATE.exchangePrices[exchangeName]||STATE.price;
  const slD = SETTINGS.slDist/100;
  const sl  = direction==='buy' ? p*(1-slD) : p*(1+slD);
  const slDist = Math.abs(p-sl);
  const tp1 = direction==='buy' ? p+slDist*SETTINGS.tp1R : p-slDist*SETTINGS.tp1R;
  const tp2 = direction==='buy' ? p+slDist*SETTINGS.tp2R : p-slDist*SETTINGS.tp2R;
  const pos = (SETTINGS.balance*(SETTINGS.riskPct/100)) / (SETTINGS.slDist/100);
  const estProfit = (pos/p)*Math.abs(tp1-p);

  updateOrderStatus(exchangeName,'active',`${direction.toUpperCase()} @ ${fmt$(p)}`,`Est. +${fmt$(estProfit)}`);

  if(ex.mode==='live'&&ex.key&&ex.secret){
    try {
      const result = await sendToExchange(exchangeName,direction,p,sl,tp1,pos);
      log(exchangeName.toUpperCase(),'trade',`${direction.toUpperCase()} order placed at ${fmt$(p)} | SL:${fmt$(sl)} | TP1:${fmt$(tp1)} | Est:+${fmt$(estProfit)}`);
    } catch(err){
      updateOrderStatus(exchangeName,'error',`Order failed: ${err.message}`,'—');
      log(exchangeName.toUpperCase(),'warn',`Order failed: ${err.message}`);
      return;
    }
  } else {
    log(exchangeName.toUpperCase(),'trade',`[SIMULATED] ${direction.toUpperCase()} @ ${fmt$(p)} | SL:${fmt$(sl)} | TP1:${fmt$(tp1)} | TP2:${fmt$(tp2)} | Est:+${fmt$(estProfit)}`);
  }

  // Record trade
  const trade = {
    time:       new Date().toISOString(),
    session:    sessionName(gmt3()),
    signal:     direction.toUpperCase(),
    exchange:   exchangeName,
    coin:       ACTIVE_COIN.base,
    entry:      p,
    sl:         sl,
    tp1:        tp1,
    tp2:        tp2,
    estProfit:  estProfit,
    score:      STATE.score,
    bor:        document.getElementById('bor-breakout')?.textContent||'—',
    greenCount: STATE.greenCount,
    result:     'PENDING',
  };

  STATE.tradeHistory.unshift(trade);
  STATE.dailyTrades++;
  STATE.sessionPnL += estProfit;
  document.getElementById('h-trades').textContent = STATE.dailyTrades;
  document.getElementById('h-pnl').textContent = '+'+fmt$(STATE.sessionPnL);
  document.getElementById('daily-count').textContent = STATE.dailyTrades;

  addTradeRow(trade);
  if(SHEETS.connected) syncTradeToSheets(trade);
}

// ─── EXCHANGE API CALLS ───────────────────────────────────────
async function sendToExchange(name, direction, price, sl, tp1, posUSDT){
  // NOTE: Direct browser API calls to exchanges require CORS proxy in production.
  // This skeleton shows the structure. Deploy backend proxy for live trading.
  const qty = (posUSDT/price).toFixed(5);

  if(name==='binance'){
    // Binance Futures USDT-M
    const baseURL = EXCHANGES.binance.mode==='testnet'
      ? 'https://testnet.binancefuture.com'
      : 'https://fapi.binance.com';
    log('BINANCE','info',`Would POST ${direction} ${qty} BTC @ market to ${baseURL}`);
    return {orderId:'SIMULATED_'+Date.now()};
  }
  if(name==='okx'){
    const baseURL = EXCHANGES.okx.mode==='testnet'?'https://www.okx.com':'https://www.okx.com';
    log('OKX','info',`Would POST ${direction} ${qty} BTC to OKX`);
    return {ordId:'SIMULATED_'+Date.now()};
  }
  if(name==='mexc'){
    log('MEXC','info',`Would POST ${direction} ${qty} BTC to MEXC`);
    return {orderId:'SIMULATED_'+Date.now()};
  }
}

