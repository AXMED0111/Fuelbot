<script>
// ══════════════════════════════════════════════════════
//  FUELBOT PASSWORD LOCK
//  Password is stored as SHA-256 hash — never plain text
//  To change password: update HASH below
//  Generate new hash at: https://emn178.github.io/online-tools/sha256.html
// ══════════════════════════════════════════════════════

// Default password: FuelBot2024!
// CHANGE THIS HASH to change your password
const STORED_HASH = 'd7f126e07619c226d8c04e83ad6e8ba660904280f6bd8801c06fe2207b3a6f82';

// Session duration: 8 hours (in ms)
const SESSION_MS = 8 * 60 * 60 * 1000;

let attempts = 0;
const MAX_ATTEMPTS = 5;
let lockoutUntil = 0;

// Check if already unlocked this session
(function initLock() {
  const stored = sessionStorage.getItem('fb_auth');
  if(stored) {
    try {
      const s = JSON.parse(stored);
      if(s.hash === STORED_HASH && Date.now() < s.exp) {
        unlockApp(false);
        return;
      }
    } catch(e){}
  }
  // Load fonts for lock screen
  const link = document.createElement('link');
  link.href = 'https://fonts.googleapis.com/css2?family=Oxanium:wght@400;700;800&family=JetBrains+Mono:wght@400&display=swap';
  link.rel = 'stylesheet';
  document.head.appendChild(link);
})();

async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function checkPassword() {
  // Lockout check
  if(Date.now() < lockoutUntil) {
    const secs = Math.ceil((lockoutUntil - Date.now()) / 1000);
    showError(`Too many attempts. Wait ${secs}s`);
    return;
  }

  const input = document.getElementById('pw-input').value;
  if(!input) { showError('Please enter your password'); return; }

  const hash = await sha256(input);

  if(hash === STORED_HASH) {
    // Save session
    sessionStorage.setItem('fb_auth', JSON.stringify({
      hash: STORED_HASH,
      exp: Date.now() + SESSION_MS
    }));
    unlockApp(true);
  } else {
    attempts++;
    document.getElementById('pw-input').value = '';

    if(attempts >= MAX_ATTEMPTS) {
      lockoutUntil = Date.now() + 30000; // 30s lockout
      attempts = 0;
      showError('Too many attempts. Locked for 30s');
      document.getElementById('lock-icon').textContent = '🔐';
    } else {
      showError(`Incorrect password (${attempts}/${MAX_ATTEMPTS} attempts)`);
      // shake animation
      const box = document.getElementById('pw-input');
      box.style.borderColor='#ff2d55';
      box.style.boxShadow='0 0 16px rgba(255,45,85,0.25)';
      setTimeout(()=>{box.style.borderColor='#172840';box.style.boxShadow='none';},800);
    }
    document.getElementById('attempt-info').textContent = `${MAX_ATTEMPTS - attempts} attempt${MAX_ATTEMPTS-attempts!==1?'s':''} remaining`;
  }
}

function unlockApp(animate) {
  const lock = document.getElementById('lock-screen');
  if(!lock) return;
  if(animate) {
    document.getElementById('lock-icon').textContent = '🔓';
    document.getElementById('lock-icon').style.filter = 'drop-shadow(0 0 12px rgba(0,255,136,0.8))';
    lock.style.transition = 'opacity 0.6s ease';
    lock.style.opacity = '0';
    setTimeout(() => { lock.style.display='none'; }, 620);
  } else {
    lock.style.display = 'none';
  }
}

function showError(msg) {
  const el = document.getElementById('pw-error');
  el.textContent = msg;
  el.style.opacity = '1';
  setTimeout(() => { el.style.opacity = '0'; }, 3000);
}

function togglePwVisibility() {
  const inp = document.getElementById('pw-input');
  const eye = document.getElementById('pw-eye');
  if(inp.type === 'password') { inp.type='text'; eye.textContent='🙈'; }
  else { inp.type='password'; eye.textContent='👁'; }
}

// Auto-focus input
setTimeout(() => {
  const inp = document.getElementById('pw-input');
  if(inp) inp.focus();
}, 100);
</script>


