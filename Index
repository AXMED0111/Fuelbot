// ─── HELPERS ──────────────────────────────────────────────────
const gmt3 = () => {
  const now = new Date();
  return new Date(now.getTime() + now.getTimezoneOffset()*60000 + 3*3600000);
};
const z = n => String(n).padStart(2,'0');
const fmt$ = (v, dp=2) => '$' + parseFloat(v).toLocaleString('en-US',{minimumFractionDigits:dp,maximumFractionDigits:dp});
const fmtPct = v => (v>=0?'+':'')+parseFloat(v).toFixed(2)+'%';

// ─── CLOCK & SESSIONS ─────────────────────────────────────────
function tickClock() {
  const t = gmt3();
  document.getElementById('clock').textContent = `${z(t.getHours())}:${z(t.getMinutes())}:${z(t.getSeconds())}`;
  updateSessionUI(t);
  updateCountdown(t);
}

function isInSession(t) {
  const h=t.getHours(), m=t.getMinutes();
  return (h===4 && m<30) || (h===16 && m<30);
}

function sessionName(t) {
  const h=t.getHours(), m=t.getMinutes();
  if(h===4&&m<30) return '4:00 AM';
  if(h===16&&m<30) return '4:00 PM';
  return 'OFF-SESSION';
}

function updateSessionUI(t) {
  const h=t.getHours(), m=t.getMinutes();
  document.getElementById('s4am').classList.toggle('active', h===4&&m<30);
  document.getElementById('s4pm').classList.toggle('active', h===16&&m<30);
  const inSess = isInSession(t);
  const sessEl = document.getElementById('tc-sess');
  sessEl.textContent = sessionName(t);
  sessEl.style.color = inSess?'var(--green)':'var(--yellow)';
}

function updateCountdown(t) {
  const s = t.getHours()*3600+t.getMinutes()*60+t.getSeconds();
  const tgts=[4*3600,16*3600];
  let min=null;
  tgts.forEach(tg=>{const d=tg>s?(tg-s):(86400-s+tg);if(min===null||d<min)min=d;});
  document.getElementById('countdown').textContent=`${z(Math.floor(min/3600))}:${z(Math.floor((min%3600)/60))}:${z(min%60)}`;
}

