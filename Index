<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FuelBot PRO v4 — Secure</title>
<link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@300;400;600;700;800&family=JetBrains+Mono:wght@300;400;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:      #04080d;
  --bg2:     #080f18;
  --bg3:     #0c1520;
  --border:  #0e1c2c;
  --border2: #172840;
  --accent:  #00c8ff;
  --green:   #00ff88;
  --green2:  #009955;
  --red:     #ff2d55;
  --red2:    #881830;
  --yellow:  #ffd000;
  --orange:  #ff7a00;
  --purple:  #a855f7;
  --muted:   #1e3050;
  --muted2:  #3a5878;
  --text:    #b0c8e0;
  --font:    'Oxanium', sans-serif;
  --mono:    'JetBrains Mono', monospace;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;overflow-x:hidden;}
body::after{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,0.025) 1px,transparent 1px);background-size:36px 36px;pointer-events:none;z-index:0;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.06) 3px,rgba(0,0,0,0.06) 4px);pointer-events:none;z-index:1;}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:1000;display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:8px;width:480px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 0 60px rgba(0,200,255,0.15);}
.modal-wide{width:600px;}
.modal-hdr{display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--border2);font-weight:700;font-size:0.9rem;letter-spacing:0.06em;}
.modal-close{background:none;border:none;color:var(--muted2);font-size:1.1rem;cursor:pointer;padding:4px 8px;border-radius:3px;}
.modal-close:hover{color:var(--red);background:rgba(255,45,85,0.1);}
.modal-body{padding:20px;}
.form-row{margin-bottom:14px;}
.form-row label{display:block;font-size:0.65rem;color:var(--muted2);letter-spacing:0.16em;text-transform:uppercase;margin-bottom:5px;}
.form-row input,.form-row select{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:8px 12px;color:var(--text);font-family:var(--mono);font-size:0.85rem;outline:none;transition:border-color 0.2s;}
.form-row input:focus,.form-row select:focus{border-color:var(--accent);}
.form-hint{font-size:0.62rem;color:var(--muted2);margin-top:3px;display:block;}
.info-box{background:rgba(0,200,255,0.05);border:1px solid rgba(0,200,255,0.2);border-radius:4px;padding:12px;font-size:0.72rem;line-height:1.6;margin-bottom:16px;color:var(--muted2);}
.info-box b{color:var(--accent);}
.info-box code{background:var(--bg3);padding:1px 5px;border-radius:2px;color:var(--yellow);}
.col-chip{background:var(--bg3);border:1px solid var(--border2);border-radius:3px;padding:2px 8px;font-size:0.6rem;color:var(--muted2);}
.api-test-row{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.exchange-tabs{display:flex;gap:6px;margin-bottom:16px;}
.etab{background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:6px 16px;font-family:var(--font);font-size:0.75rem;color:var(--muted2);cursor:pointer;transition:all 0.2s;}
.etab.active{border-color:var(--accent);color:var(--accent);background:rgba(0,200,255,0.07);}
.exchange-form.hidden{display:none;}
.ex-status-row{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding:10px;background:var(--bg3);border-radius:4px;}
.toggle-wrap{display:flex;align-items:center;gap:8px;}
.toggle{position:relative;display:inline-block;width:36px;height:20px;}
.toggle input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:var(--muted);border-radius:20px;transition:0.3s;cursor:pointer;}
.toggle-slider::before{content:'';position:absolute;width:14px;height:14px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:0.3s;}
.toggle input:checked+.toggle-slider{background:var(--green2);}
.toggle input:checked+.toggle-slider::before{transform:translateX(16px);}

/* ── HEADER ── */
header{position:relative;z-index:10;display:flex;justify-content:space-between;align-items:center;padding:12px 20px;border-bottom:1px solid var(--border2);background:linear-gradient(180deg,rgba(0,200,255,0.04),transparent);}
.logo{font-family:var(--font);font-size:1.2rem;font-weight:800;letter-spacing:0.15em;background:linear-gradient(90deg,var(--accent),var(--green));-webkit-background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 8px rgba(0,200,255,0.35));}
.logo sub{font-size:0.45rem;letter-spacing:0.3em;-webkit-text-fill-color:var(--yellow);margin-left:4px;}
.hdr-center{display:flex;gap:18px;align-items:center;}
.hdr-stat{text-align:center;font-size:0.63rem;}
.hdr-stat .val{font-family:var(--mono);font-size:0.88rem;font-weight:600;display:block;color:var(--accent);}
.hdr-stat .lbl{color:var(--muted2);letter-spacing:0.1em;}
.hdr-right{display:flex;gap:10px;align-items:center;}
.live-pill{display:flex;align-items:center;gap:5px;background:rgba(0,255,136,0.07);border:1px solid var(--green2);border-radius:20px;padding:3px 9px;font-size:0.65rem;color:var(--green);letter-spacing:0.1em;}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 1.1s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.1}}
#clock{font-family:var(--mono);font-size:0.95rem;color:var(--accent);letter-spacing:0.06em;}
#clock-tz{font-size:0.58rem;color:var(--muted2);}

/* ── EXCHANGE BAR ── */
.exchange-bar{position:relative;z-index:9;display:flex;align-items:center;gap:8px;padding:8px 20px;background:var(--bg2);border-bottom:1px solid var(--border);}
.ex-chip{display:flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:5px 10px;font-size:0.68rem;}
.ex-chip-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:blink 1.2s infinite;}
.ex-chip-dot.idle{background:var(--muted);box-shadow:none;animation:none;}
.ex-chip-dot.error{background:var(--red);box-shadow:0 0 6px var(--red);animation:blink 0.7s infinite;}
.ex-chip-name{font-weight:700;color:var(--text);}
.ex-chip-status{color:var(--green);font-family:var(--mono);font-size:0.62rem;}
.ex-chip-price{color:var(--accent);font-family:var(--mono);font-size:0.72rem;}
.ex-chip-btn{background:none;border:1px solid var(--border2);border-radius:3px;color:var(--muted2);font-size:0.68rem;cursor:pointer;padding:1px 5px;transition:all 0.2s;}
.ex-chip-btn:hover{border-color:var(--accent);color:var(--accent);}

/* ── LAYOUT ── */
.app{position:relative;z-index:5;display:grid;grid-template-columns:280px 1fr 230px;grid-template-rows:auto auto auto auto auto;gap:10px;padding:12px 16px;max-width:1500px;margin:0 auto;}

/* ── PANELS ── */
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:14px;position:relative;overflow:hidden;transition:border-color 0.3s;}
.panel-hdr{font-size:0.58rem;font-weight:700;letter-spacing:0.22em;color:var(--muted2);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.panel-hdr::before{content:'';display:block;width:2px;height:9px;background:var(--accent);border-radius:2px;flex-shrink:0;}

/* ── LEFT COLUMN ── */
.col-left{grid-column:1;grid-row:1/5;display:flex;flex-direction:column;gap:8px;}
.sess-row{display:flex;gap:5px;margin-bottom:8px;}
.sess-pill{flex:1;text-align:center;font-size:0.62rem;letter-spacing:0.1em;padding:4px;border-radius:3px;border:1px solid var(--border2);color:var(--muted2);transition:all 0.3s;}
.sess-pill.active{border-color:var(--accent);color:var(--accent);background:rgba(0,200,255,0.07);box-shadow:0 0 12px rgba(0,200,255,0.15);}
.signal-main{border-radius:5px;padding:18px 14px;text-align:center;border:1px solid var(--border);transition:all 0.5s;position:relative;overflow:hidden;}
.signal-main::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(0,200,255,0.07),transparent 70%);transition:all 0.5s;}
.signal-main.s-buy{border-color:var(--green);background:rgba(0,255,136,0.03);}
.signal-main.s-buy::before{background:radial-gradient(ellipse at 50% 0%,rgba(0,255,136,0.1),transparent 70%);}
.signal-main.s-sell{border-color:var(--red);background:rgba(255,45,85,0.03);}
.signal-main.s-sell::before{background:radial-gradient(ellipse at 50% 0%,rgba(255,45,85,0.1),transparent 70%);}
.signal-main.s-skip{border-color:var(--yellow);}
.sig-icon{font-size:2.2rem;display:block;margin-bottom:4px;}
.signal-main.s-buy .sig-icon{animation:pg 1.5s infinite;}
.signal-main.s-sell .sig-icon{animation:pr 1.5s infinite;}
@keyframes pg{0%,100%{filter:drop-shadow(0 0 5px rgba(0,255,136,0.3))}50%{filter:drop-shadow(0 0 14px rgba(0,255,136,0.8))}}
@keyframes pr{0%,100%{filter:drop-shadow(0 0 5px rgba(255,45,85,0.3))}50%{filter:drop-shadow(0 0 14px rgba(255,45,85,0.8))}}
.sig-word{font-family:var(--font);font-size:2rem;font-weight:800;letter-spacing:0.1em;}
.s-buy .sig-word{color:var(--green);text-shadow:0 0 20px rgba(0,255,136,0.4);}
.s-sell .sig-word{color:var(--red);text-shadow:0 0 20px rgba(255,45,85,0.4);}
.s-skip .sig-word{color:var(--yellow);}
.s-wait .sig-word{color:var(--muted2);}
.sig-sub{font-size:0.62rem;color:var(--muted2);letter-spacing:0.1em;margin-top:3px;}
.conf-wrap{margin-top:8px;}
.conf-label{display:flex;justify-content:space-between;font-size:0.62rem;color:var(--muted2);margin-bottom:3px;}
.conf-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.conf-fill{height:100%;border-radius:2px;transition:width 0.7s;background:linear-gradient(90deg,var(--red),var(--yellow),var(--green));}
.exec-row{display:flex;gap:6px;margin-top:10px;}
.btn-buy{flex:1;background:rgba(0,255,136,0.1);color:var(--green);border:1px solid var(--green2);border-radius:3px;padding:8px;font-family:var(--font);font-size:0.72rem;font-weight:700;cursor:pointer;letter-spacing:0.08em;transition:all 0.2s;}
.btn-buy:hover{background:rgba(0,255,136,0.2);}
.btn-sell{flex:1;background:rgba(255,45,85,0.1);color:var(--red);border:1px solid var(--red2);border-radius:3px;padding:8px;font-family:var(--font);font-size:0.72rem;font-weight:700;cursor:pointer;letter-spacing:0.08em;transition:all 0.2s;}
.btn-sell:hover{background:rgba(255,45,85,0.2);}
.kv-row{display:flex;justify-content:space-between;align-items:center;font-size:0.7rem;padding:5px 0;border-bottom:1px solid var(--border);}
.kv-row:last-child{border-bottom:none;}
.kv-row .k{color:var(--muted2);}
.kv-row .v{font-family:var(--mono);font-weight:600;color:var(--accent);}
.kv-row .v.g{color:var(--green);}
.kv-row .v.r{color:var(--red);}
.kv-row .v.y{color:var(--yellow);}

/* PROFIT PANEL */
.profit-panel{}
.profit-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.profit-cell{border:1px solid var(--border2);border-radius:4px;padding:8px 10px;}
.profit-lbl{font-size:0.58rem;color:var(--muted2);letter-spacing:0.12em;margin-bottom:4px;}
.profit-val{font-family:var(--mono);font-size:0.85rem;font-weight:600;color:var(--accent);}
.profit-val.g{color:var(--green);}
.profit-val.r{color:var(--red);}
.profit-val.y{color:var(--yellow);}
.profit-val.accent{color:var(--accent);}
.profit-bar-wrap{margin-top:6px;}
.profit-bar-labels{display:flex;justify-content:space-between;font-size:0.58rem;color:var(--muted2);margin-bottom:4px;}
.profit-bar-track{height:8px;background:var(--border);border-radius:4px;overflow:hidden;display:flex;}
.profit-bar-loss{background:rgba(255,45,85,0.5);height:100%;transition:width 0.5s;}
.profit-bar-gain{background:linear-gradient(90deg,var(--green2),var(--green));height:100%;transition:width 0.5s;}
.cd-box{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px;}
.cd-lbl{font-size:0.55rem;color:var(--muted2);letter-spacing:0.18em;margin-bottom:4px;}
#countdown{font-family:var(--mono);font-size:1.3rem;color:var(--yellow);}

/* ── CENTER ── */
.col-center-top{grid-column:2;grid-row:1;}
.col-center-mid{grid-column:2;grid-row:2;}
.col-center-bot{grid-column:2;grid-row:3/5;}

.bor-visual{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:10px;}
.bor-level{border:1px solid var(--border2);border-radius:4px;padding:9px;text-align:center;position:relative;}
.bor-level::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;}
.high-lvl::after{background:var(--green);}
.mid-lvl::after{background:var(--yellow);}
.low-lvl::after{background:var(--red);}
.bor-lbl{font-size:0.55rem;color:var(--muted2);letter-spacing:0.12em;margin-bottom:4px;}
.bor-val{font-family:var(--mono);font-size:0.85rem;font-weight:600;}
.high-lvl .bor-val{color:var(--green);}
.mid-lvl .bor-val{color:var(--yellow);}
.low-lvl .bor-val{color:var(--red);}
.bor-dist{font-size:0.58rem;color:var(--muted2);margin-top:2px;}
.bor-labels{display:flex;justify-content:space-between;font-size:0.55rem;color:var(--muted2);margin-bottom:4px;}
.bor-position-bar{position:relative;height:24px;background:var(--bg3);border:1px solid var(--border2);border-radius:3px;overflow:hidden;margin-bottom:6px;}
.bor-zone{position:absolute;top:0;bottom:0;background:rgba(0,255,136,0.06);border-left:1px solid var(--green2);border-right:1px solid var(--green2);}
.bor-price-line{position:absolute;top:0;bottom:0;width:2px;background:var(--accent);box-shadow:0 0 8px var(--accent);transition:left 0.5s;}
.tcell{border:1px solid var(--border2);border-radius:4px;padding:8px 10px;}
.tc-lbl{font-size:0.58rem;color:var(--muted2);letter-spacing:0.12em;margin-bottom:4px;}
.tc-val{font-family:var(--mono);font-size:0.85rem;font-weight:600;color:var(--accent);}
.tc-val.g{color:var(--green);}
.tc-val.r{color:var(--red);}
.tc-val.y{color:var(--yellow);}
#mini-chart{width:100%;height:80px;display:block;}
.candles-wrap{display:flex;gap:7px;margin-bottom:9px;}
.c-card{flex:1;border:1px solid var(--border2);border-radius:4px;padding:10px 7px;text-align:center;transition:all 0.3s;position:relative;}
.c-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--border2);transition:background 0.3s;}
.c-card.gc::after{background:var(--green);}
.c-card.rc::after{background:var(--red);}
.c-card.gc{background:rgba(0,255,136,0.03);}
.c-card.rc{background:rgba(255,45,85,0.03);}
.c-num{font-size:0.55rem;color:var(--muted2);letter-spacing:0.1em;margin-bottom:5px;}
.c-body-vis{width:14px;height:36px;margin:0 auto 5px;border:2px solid var(--muted);border-radius:1px;transition:all 0.3s;}
.c-card.gc .c-body-vis{border-color:var(--green);background:rgba(0,255,136,0.15);}
.c-card.rc .c-body-vis{border-color:var(--red);background:rgba(255,45,85,0.15);}
.c-pct{font-family:var(--mono);font-size:0.78rem;font-weight:600;}
.c-card.gc .c-pct{color:var(--green);}
.c-card.rc .c-pct{color:var(--red);}
.c-body-size{font-size:0.58rem;color:var(--muted2);margin-top:2px;}
.candle-verdict-row{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);border-radius:3px;padding:7px 10px;}
.dot-set{display:flex;gap:4px;}
.dot{width:11px;height:11px;border-radius:2px;background:var(--muted);transition:all 0.3s;}
.dot.g{background:var(--green);box-shadow:0 0 6px var(--green);}
.dot.r{background:var(--red);box-shadow:0 0 6px var(--red);}
.cverd{margin-left:auto;font-size:0.68rem;font-weight:700;letter-spacing:0.12em;padding:2px 8px;border-radius:2px;}
.cverd.enter{color:var(--green);border:1px solid var(--green);}
.cverd.skip{color:var(--yellow);border:1px solid var(--yellow);}
.tgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;}

/* ORDER STATUS */
.order-status-grid{display:flex;flex-direction:column;gap:6px;}
.order-row{display:flex;align-items:center;gap:10px;background:var(--bg3);border:1px solid var(--border2);border-radius:4px;padding:8px 12px;}
.ord-ex-name{display:flex;align-items:center;gap:7px;font-size:0.72rem;font-weight:600;min-width:80px;}
.ord-status{font-size:0.62rem;font-weight:700;letter-spacing:0.12em;padding:2px 8px;border-radius:2px;min-width:80px;text-align:center;}
.ord-status.idle{color:var(--muted2);border:1px solid var(--muted);}
.ord-status.active{color:var(--green);border:1px solid var(--green2);background:rgba(0,255,136,0.07);}
.ord-status.filled{color:var(--yellow);border:1px solid var(--yellow);}
.ord-status.error{color:var(--red);border:1px solid var(--red2);}
.ord-detail{flex:1;font-size:0.65rem;color:var(--muted2);}
.ord-profit{font-family:var(--mono);font-size:0.72rem;font-weight:600;color:var(--accent);}

/* ── RIGHT ── */
.col-right{grid-column:3;grid-row:1/4;display:flex;flex-direction:column;gap:8px;}
.score-ring-wrap{display:flex;flex-direction:column;align-items:center;padding:4px 0 8px;}
.filter-list{display:flex;flex-direction:column;gap:5px;}
.filter-item{display:flex;align-items:center;gap:7px;font-size:0.67rem;padding:5px 8px;border:1px solid var(--border);border-radius:3px;background:var(--bg3);}
.filter-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.filter-dot.pass{background:var(--green);box-shadow:0 0 5px var(--green);}
.filter-dot.fail{background:var(--red);box-shadow:0 0 5px var(--red);}
.filter-dot.warn{background:var(--yellow);box-shadow:0 0 5px var(--yellow);}
.filter-dot.idle{background:var(--muted);}
.filter-name{flex:1;color:var(--muted2);}
.filter-val{font-family:var(--mono);font-size:0.62rem;color:var(--accent);}

/* ── NEWS BAR ── */
.news-bar{grid-column:1/4;grid-row:5;display:flex;align-items:center;gap:10px;padding:8px 14px;}
#news-txt{flex:0 1 auto;font-size:0.72rem;}
.news-safe{color:var(--green);}
.news-warn{color:var(--red);}

/* ── LOG FULL ── */
.log-panel-full{grid-column:1/4;grid-row:6;}
.trade-table-wrap{overflow-x:auto;max-height:200px;overflow-y:auto;}
.trade-table{width:100%;border-collapse:collapse;font-size:0.65rem;}
.trade-table th{background:var(--bg3);color:var(--muted2);letter-spacing:0.12em;padding:6px 8px;text-align:left;position:sticky;top:0;border-bottom:1px solid var(--border2);}
.trade-table td{padding:5px 8px;border-bottom:1px solid var(--border);font-family:var(--mono);}
.trade-table tr:hover td{background:rgba(0,200,255,0.03);}
.td-buy{color:var(--green);}
.td-sell{color:var(--red);}
.td-profit{color:var(--green);}
.td-win{color:var(--green);font-weight:700;}
.td-loss{color:var(--red);font-weight:700;}
.td-pending{color:var(--yellow);}

/* ── BUTTONS ── */
.btn{font-family:var(--mono);font-size:0.68rem;letter-spacing:0.1em;padding:6px 13px;border-radius:3px;border:none;cursor:pointer;transition:all 0.2s;}
.btn-accent{background:rgba(0,200,255,0.12);color:var(--accent);border:1px solid var(--accent2);width:100%;margin-top:6px;padding:9px;}
.btn-accent:hover{background:rgba(0,200,255,0.22);}
.btn-outline{background:transparent;color:var(--muted2);border:1px solid var(--border2);}
