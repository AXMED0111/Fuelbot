async function syncTradeToSheets(trade){
  if(!SHEETS.url){log('SHEETS','warn','No Sheets URL configured');return;}
  try {
    await fetch(SHEETS.url+'?action=log',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        sheet:  SHEETS.name,
        row: [
          new Date(trade.time).toLocaleString(),
          trade.session,
          trade.signal,
          trade.exchange,
          trade.coin||ACTIVE_COIN.base,
          trade.entry,
          trade.sl,
          trade.tp1,
          trade.tp2,
          SETTINGS.riskPct+'%',
          '',
          '+$'+trade.estProfit.toFixed(2),
          trade.score,
          trade.bor,
          trade.greenCount+'/3',
          trade.result,
          '',
          'Auto-placed by FuelBot PRO v4',
        ]
      })
