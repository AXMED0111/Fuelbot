function buildCoinBar() {
  const bar = document.getElementById('coin-bar');
  // clear existing pills (keep search)
  bar.querySelectorAll('.coin-pill').forEach(p=>p.remove());
  const searchWrap = bar.querySelector('.coin-search-wrap');

  const visible = COIN_CATALOGUE.filter(c => watchSymbols.includes(c.symbol));
  visible.forEach(coin => {
    const pill = document.createElement('div');
    pill.className = 'coin-pill' + (coin.symbol===ACTIVE_COIN.symbol?' active':'');
    pill.id = 'pill-'+coin.symbol;
    const cached = coinCache[coin.symbol];
    const chg = cached ? cached.change24h : null;
    const chgHtml = chg!==null ? `<span class="coin-chg ${chg>=0?'up':'dn'}">${chg>=0?'+':''}${chg.toFixed(1)}%</span>` : '';
    pill.innerHTML = `<span class="coin-icon">${coin.icon}</span><span>${coin.base}</span>${chgHtml}`;
    pill.onclick = () => switchCoin(coin.symbol);
    bar.insertBefore(pill, searchWrap);
  });
}

function switchCoin(symbol) {
  const coin = COIN_CATALOGUE.find(c=>c.symbol===symbol);
  if(!coin) return;
  ACTIVE_COIN = coin;
  // reset state
  STATE.price=null;STATE.prevPrice=null;STATE.candles=[];
  STATE.priceHistory=[];STATE.borHigh=null;STATE.borLow=null;STATE.borMid=null;
  STATE.lastSignal='wait';STATE.score=0;STATE.greenCount=0;
  // update UI
  buildCoinBar();
  updateWatchGrid();
  document.getElementById('sig-word').textContent='WAIT';
  document.getElementById('sig-box').className='signal-main s-wait';
  log('COIN','info','Switched to '+coin.base+'/USDT — fetching data…');
  fetchPrice();
  fetchCandles();
}

function searchCoin(q) {
  q = q.trim().toUpperCase();
  if(!q){ buildCoinBar(); return; }
  const bar = document.getElementById('coin-bar');
  bar.querySelectorAll('.coin-pill').forEach(p=>p.remove());
  const searchWrap = bar.querySelector('.coin-search-wrap');
  const matches = COIN_CATALOGUE.filter(c=>c.base.includes(q)||c.label.toUpperCase().includes(q));
  matches.slice(0,12).forEach(coin=>{
    const pill = document.createElement('div');
    pill.className = 'coin-pill'+(coin.symbol===ACTIVE_COIN.symbol?' active':'');
    pill.innerHTML = `<span class="coin-icon">${coin.icon}</span><span>${coin.base}</span>`;
    pill.onclick = () => { switchCoin(coin.symbol); document.getElementById('coin-search').value=''; buildCoinBar(); };
    bar.insertBefore(pill, searchWrap);
  });
}

function addCustomCoin() {
  const sym = prompt('Enter Binance symbol (e.g. FETUSDT, RENDERUSDT):');
  if(!sym) return;
  const clean = sym.trim().toUpperCase();
  if(!clean.endsWith('USDT') && !clean.endsWith('BTC')) { alert('Symbol must end in USDT or BTC'); return; }
  const base = clean.replace(/USDT|BTC$/,'');
  const exists = COIN_CATALOGUE.find(c=>c.symbol===clean);
  if(!exists) {
    COIN_CATALOGUE.push({ symbol:clean, base, label:base, icon:'◈', decimals:4, minQty:1 });
  }
  if(!watchSymbols.includes(clean)) watchSymbols.push(clean);
  switchCoin(clean);
  log('COIN','info','Custom coin added: '+clean);
}

// ─── WATCHLIST SCANNER ────────────────────────────────────────
async function scanWatchlist() {
  const symbols = watchSymbols.join(',');
  try {
    // Batch fetch all prices at once using Binance bookTicker or 24hr
    const url = 'https://api.binance.com/api/v3/ticker/24hr?symbols=['+watchSymbols.map(s=>'"'+s+'"').join(',')+']';
    const r = await fetch(url);
    const data = await r.json();
    if(!Array.isArray(data)) return;
    data.forEach(t => {
      const sym = t.symbol;
      const price = parseFloat(t.lastPrice);
      const chg   = parseFloat(t.priceChangePercent);
      if(!coinCache[sym]) coinCache[sym]={price,change24h:chg,signal:'wait',candles:[]};
      else { coinCache[sym].price=price; coinCache[sym].change24h=chg; }
    });
    // quick candle scan for all watch coins (batch)
    await quickCandleScan();
    updateWatchGrid();
    buildCoinBar(); // refresh change % on pills
  } catch(e) {}
}

async function quickCandleScan() {
  // scan each watchlisted coin for signal quality
  for(const sym of watchSymbols) {
    try {
      const r = await fetch('https://api.binance.com/api/v3/klines?symbol='+sym+'&interval=15m&limit=4');
      const d = await r.json();
      if(!Array.isArray(d)) continue;
      const candles = d.slice(0,3).map(c=>({
        open:parseFloat(c[1]),close:parseFloat(c[4]),green:parseFloat(c[4])>parseFloat(c[1])
      }));
      const gc = candles.filter(c=>c.green).length;
      let sig='wait';
      if(gc>=2 && candles[2].green) sig='buy';
      else if(gc>=2 && !candles[2].green) sig='sell';
      else sig='skip';
      if(!coinCache[sym]) coinCache[sym]={signal:sig,greenCount:gc,candles};
      else { coinCache[sym].signal=sig; coinCache[sym].greenCount=gc; coinCache[sym].candles=candles; }
    } catch(e){}
    await new Promise(r=>setTimeout(r,80)); // small delay to avoid rate limit
  }
}

function updateWatchGrid() {
  const grid = document.getElementById('watch-grid');
  if(!grid) return;
  grid.innerHTML='';
  watchSymbols.forEach(sym => {
    const coin = COIN_CATALOGUE.find(c=>c.symbol===sym);
    const cached = coinCache[sym]||{};
    const isActive = sym===ACTIVE_COIN.symbol;
    const sig = cached.signal||'wait';
    const price = cached.price;
    const chg   = cached.change24h;
    const cell  = document.createElement('div');
    cell.className = `watch-cell ${isActive?'active-coin':''} ${sig!=='wait'&&sig!=='skip'?'sig-'+sig:''}`;
    cell.innerHTML = `
      <div class="wc-sym">${coin?coin.icon:''} ${coin?coin.base:sym.replace('USDT','')}</div>
      <div class="wc-price">${price?'$'+price.toLocaleString('en-US',{maximumFractionDigits:coin?coin.decimals:4}):'—'}</div>
      <div class="wc-chg" style="color:${chg>=0?'var(--green)':'var(--red)'}">${chg!=null?(chg>=0?'+':'')+chg.toFixed(2)+'%':'—'}</div>
      <div class="wc-sig ${sig}">${sig.toUpperCase()}</div>`;
    cell.onclick = () => switchCoin(sym);
    grid.appendChild(cell);
  });
  // scan status
  const anyBuy  = Object.values(coinCache).filter(c=>c.signal==='buy').length;
  const anySell = Object.values(coinCache).filter(c=>c.signal==='sell').length;
  document.getElementById('wl-scan-status').textContent =
    `${anyBuy} BUY · ${anySell} SELL opportunities across ${watchSymbols.length} coins`;
}

// format price respecting coin decimals
function fmtCoin(v) {
  const dp = ACTIVE_COIN.decimals;
  return '$'+parseFloat(v).toLocaleString('en-US',{minimumFractionDigits:dp,maximumFractionDigits:dp});
}


