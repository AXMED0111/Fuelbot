// ─── MINI CHART ───────────────────────────────────────────────
function drawChart(){
  const canvas=document.getElementById('mini-chart');
  if(!canvas) return;
  canvas.width=canvas.offsetWidth*window.devicePixelRatio||canvas.offsetWidth*2;
  canvas.height=80*window.devicePixelRatio||160;
  const ctx=canvas.getContext('2d');
  const pts=STATE.priceHistory;
  if(pts.length<2){ctx.clearRect(0,0,canvas.width,canvas.height);return;}
  const W=canvas.width,H=canvas.height,pad=8;
  const mn=Math.min(...pts),mx=Math.max(...pts),range=mx-mn||1;
  ctx.clearRect(0,0,W,H);

  // BOR bands
  if(STATE.borHigh&&STATE.borLow){
    const yH=H-pad-((STATE.borHigh-mn)/range*(H-2*pad));
    const yL=H-pad-((STATE.borLow-mn)/range*(H-2*pad));
    ctx.fillStyle='rgba(0,255,136,0.05)';
    ctx.fillRect(0,yH,W,yL-yH);
    [['rgba(0,255,136,0.35)',yH],['rgba(255,45,85,0.35)',yL],['rgba(255,208,0,0.3)',H-pad-((STATE.borMid-mn)/range*(H-2*pad))]].forEach(([c,y])=>{
      ctx.strokeStyle=c;ctx.lineWidth=1;ctx.setLineDash([3,4]);
      ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();
    });
    ctx.setLineDash([]);
  }

  // line
  const g=ctx.createLinearGradient(0,0,W,0);
  g.addColorStop(0,'rgba(0,200,255,0.4)');
  g.addColorStop(1,'rgba(0,200,255,1)');
  ctx.strokeStyle=g;ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.lineCap='round';
  ctx.beginPath();
  pts.forEach((v,i)=>{
    const x=pad+(i/(pts.length-1))*(W-2*pad);
    const y=H-pad-((v-mn)/range*(H-2*pad));
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  ctx.stroke();

  // fill
  const ag=ctx.createLinearGradient(0,0,0,H);
  ag.addColorStop(0,'rgba(0,200,255,0.12)');
  ag.addColorStop(1,'rgba(0,200,255,0)');
  ctx.fillStyle=ag;
  ctx.beginPath();
  pts.forEach((v,i)=>{
    const x=pad+(i/(pts.length-1))*(W-2*pad);
    const y=H-pad-((v-mn)/range*(H-2*pad));
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  const lx=pad+W-2*pad;
  ctx.lineTo(lx,H-pad);ctx.lineTo(pad,H-pad);ctx.closePath();ctx.fill();

  // dot
  const ly=H-pad-((pts[pts.length-1]-mn)/range*(H-2*pad));
  ctx.fillStyle='var(--accent)';ctx.shadowColor='var(--accent)';ctx.shadowBlur=7;
  ctx.beginPath();ctx.arc(lx,ly,3.5,0,Math.PI*2);ctx.fill();
  ctx.shadowBlur=0;
}

